# --- Telegram ---
# Один токен бота. Бот має бути доданий і admin'ом у всі чати/канали з TELEGRAM_CHAT_IDS.
TELEGRAM_BOT_TOKEN=
# Кілька чатів через кому. ID каналу — від'ємне число (напр. -1001234567890).
# Як дізнатись chat_id каналу: додай @userinfobot або @getidsbot як admin, або глянь через https://api.telegram.org/bot<TOKEN>/getUpdates після того як надішлеш повідомлення в чат.
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# --- Контракт пулів Binance Alpha (адресат тіла tx) ---
# 0xb0BAa371b899950B4Ef6A27c21bAf5ef7c434d0f
