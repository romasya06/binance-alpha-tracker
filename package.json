{
  "name": "binance-alpha-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Tenderly webhook receiver: monitors Binance Alpha pool contract for setPoolStartedTimestamp calls and posts the scheduled start time to Telegram (with edit-on-reschedule).",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "pino": "^9.3.2",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.33",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
